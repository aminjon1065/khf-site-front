# Публичный сайт КЧС — переменные окружения.
# Скопируйте в `.env.local` и оставьте раскомментированным ОДИН блок —
# под вашу локальную среду (Laragon или Herd).
#
#   API_URL             — база API CMS для серверных вызовов Next.js (SSR/ISR).
#   NEXT_PUBLIC_API_URL  — та же база для клиентских вызовов (форма обращений,
#                          поиск). Должна быть доступна из браузера и разрешена
#                          в CORS_ALLOWED_ORIGINS на стороне CMS.

# ── Laragon (Windows, на работе) ───────────────────────────────────────────
# CMS отдаётся на порту 8848 (`php artisan serve` или vhost laragon).
API_URL=http://127.0.0.1:8848/api/v1
NEXT_PUBLIC_API_URL=http://127.0.0.1:8848/api/v1

# ── Laravel Herd (macOS) ───────────────────────────────────────────────────
# Herd отдаёт сайт по домену «<папка-проекта>.test» (обычно khf-site-cms.test),
# без порта. Используйте http:// — тогда серверный fetch Next.js не упрётся в
# локальный TLS-сертификат Herd. Домен при необходимости замените на свой.
# API_URL=http://khf-site-cms.test/api/v1
# NEXT_PUBLIC_API_URL=http://khf-site-cms.test/api/v1

# ── Ревалидация ISR по вебхуку из CMS ──────────────────────────────────────
# REVALIDATION_SECRET должен ПОБУКВЕННО совпадать с FRONTEND_REVALIDATION_SECRET
# в .env CMS. При публикации/обновлении контента CMS шлёт POST /api/revalidate
# c Authorization: Bearer <секрет>; фронт вызывает revalidateTag('cms').
# Сгенерировать: openssl rand -hex 32
REVALIDATION_SECRET=

# ── Публичный адрес сайта ──────────────────────────────────────────────────
# Используется для canonical, OpenGraph, hreflang и sitemap.xml (абсолютные URL).
NEXT_PUBLIC_SITE_URL=https://khf.tj
